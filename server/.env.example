# Gmail credentials — copy this file to .env and fill in your values
# 1. Enable 2-Step Verification on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create an App Password for "Mail" → copy the 16-char code below

EMAIL_USER=srikarpuyal.me@gmail.com
EMAIL_PASS=your_16_char_app_password_here

# Port the backend runs on (Vite proxies /api → this port)
PORT=3001
